# Server
APP_ENV=development
APP_PORT=8080
APP_LOG_LEVEL=info
APP_SHUTDOWN_TIMEOUT=30s

# Database
DATABASE_URL=postgres://marketplace:marketplace@localhost:5432/marketplace?sslmode=disable
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=30m

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Observability (optional in development)
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=marketplace-golang-api
OTEL_TRACES_SAMPLER_RATIO=0.1

# Admin bootstrap (Phase 1 only — replaced in Phase 2)
ADMIN_API_TOKEN=change-me-in-production

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Object storage (Cloudflare R2 or S3-compatible)
STORAGE_ENDPOINT=https://<account>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=changeme
STORAGE_SECRET_ACCESS_KEY=changeme
STORAGE_BUCKET=marketplace
STORAGE_REGION=auto
STORAGE_PUBLIC_BASE_URL=https://cdn.example.com/marketplace
STORAGE_USE_PATH_STYLE=true

# Email (Phase 2a)
EMAIL_PROVIDER=log
EMAIL_FROM_ADDRESS=no-reply@localhost
EMAIL_FROM_NAME=Loja
EMAIL_VERIFY_LINK_BASE_URL=http://localhost:3000/verify
EMAIL_RESET_LINK_BASE_URL=http://localhost:3000/reset
SES_REGION=
SES_CONFIGURATION_SET=

# Sessions (Phase 2a)
SESSION_TTL_DEFAULT=336h
SESSION_TTL_REMEMBER_ME=720h
SESSION_REFRESH_AFTER=24h

# CSRF / RateLimit / Cookies (Phase 2a)
CSRF_ALLOWED_ORIGINS=http://localhost:3000
RATELIMIT_TRUSTED_PROXIES=
COOKIES_SECURE_PREFIX=false

# ViaCEP (Phase 2b — added now to keep config consistent)
VIACEP_BASE_URL=https://viacep.com.br/ws
VIACEP_TIMEOUT=3s
VIACEP_CACHE_TTL=1h
